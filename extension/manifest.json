{
  "manifest_version": 3,
  "name": "Job Application Tracker & Pipeline Manager",
  "version": "1.0",
  "description": "Track and manage your entire job search pipeline directly from the browser.",
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": [
    "http://localhost:8000/*"
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "notifications",
    "downloads"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}
